---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <div class="hero-text">
          <h1>Building solutions that solve problems and <span class="text-gradient">create value.</span></h1>
          <p>I'm Jack Faris, a sales leader and robotics specialist with experience at Medtronic. My mission is to leverage technology and AI to build something meaningful for society while creating financial freedom.</p>
          
          <div class="hero-image-container">
             <img src="/images/jack-headshot.jpg" alt="Jack Faris" />
          </div>

          <div class="hero-buttons" style="margin-top: 2rem;">
            <a href="/about" class="btn">Learn More</a>
            <a href="/contact" class="btn btn-secondary">Get in Touch</a>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <section>
    <div class="container">
      <div class="section-header">
        <h2 class="text-gradient-red">Current Focus</h2>
        <p>Medtronic Hugo RAS Platform — Certified specialist running robotic-assisted surgery cases and demonstrating clinical value to surgeons and healthcare systems.</p>
      </div>
      
      <div class="grid grid-2">
        <div class="card glass-panel">
          <h3><span style="font-size: 1.5rem">🏥</span> Medical Devices</h3>
          <p>Certified in Medtronic's Hugo Robotic-Assisted Surgery platform.</p>
        </div>
        
        <div class="card glass-panel">
          <h3><span style="font-size: 1.5rem">🤖</span> AI & Technology</h3>
          <p>Exploring AI agents and automation to solve real-world problems. Building OpenClaw as a platform to create value for small businesses and individuals.</p>
        </div>
      </div>
    </div>
  </section>
  
  <section>
    <div class="container">
      <div class="section-header">
        <h2 class="text-gradient-red">Mission</h2>
      </div>
      <div class="glass-panel" style="padding: 3rem; text-align: center; max-width: 800px; margin: 0 auto;">
        <p style="font-size: 1.25rem; color: #fff; margin: 0 auto;">To build something that solves a problem for society and creates financial freedom — while helping others leverage technology to do the same.</p>
      </div>
    </div>
  </section>
</Layout>
