---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <h1>Building solutions that solve problems and create value.</h1>
        <p>I'm Jack Faris, a sales leader and robotics specialist with experience at Medtronic, Enterprise Mobility, and Arthrex. My mission is to leverage technology and AI to build something meaningful for society while creating financial freedom.</p>
        <div class="hero-buttons">
          <a href="/about" class="btn">Learn More</a>
          <a href="/contact" class="btn btn-secondary">Get in Touch</a>
        </div>
      </div>
    </div>
  </section>
  
  <section>
    <div class="container">
      <div class="section-header">
        <h2>Current Focus</h2>
        <p>Medtronic Hugo RAS Platform — Certified specialist running robotic-assisted surgery cases and demonstrating clinical value to surgeons and healthcare systems.</p>
      </div>
      
      <div class="grid grid-3">
        <div class="card">
          <h3>🎯 Sales Leadership</h3>
          <p>Branch Manager at Enterprise Mobility with 44% profit growth and 5 team promotions. Experienced in B2B sales, team development, and P&L management.</p>
        </div>
        
        <div class="card">
          <h3>🏥 Medical Devices</h3>
          <p>Certified in Medtronic's Hugo Robotic-Assisted Surgery platform. Running prostatectomy and hysterectomy cases with strong surgeon feedback.</p>
        </div>
        
        <div class="card">
          <h3>🤖 AI & Technology</h3>
          <p>Exploring AI agents and automation to solve real-world problems. Building OpenClaw as a platform to create value for small businesses and individuals.</p>
        </div>
      </div>
    </div>
  </section>
  
  <section style="background: var(--color-accent-light);">
    <div class="container">
      <div class="section-header">
        <h2>Mission</h2>
        <p>To build something that solves a problem for society and creates financial freedom — while helping others leverage technology to do the same.</p>
      </div>
    </div>
  </section>
</Layout>
