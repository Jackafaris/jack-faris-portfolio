---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <section class="hero">
    <div class="container">
      <h1>Contact</h1>
      <p>Interested in connecting? I'm always open to discussing new opportunities, partnerships, or ideas.</p>
    </div>
  </section>
  
  <section>
    <div class="container">
      <div class="section-header">
        <h2>Get in Touch</h2>
        <p>Whether you're interested in my experience with robotics and medical devices, want to discuss AI and automation for your business, or just want to connect — I'd love to hear from you.</p>
      </div>
      
      <div class="grid grid-2">
        <div>
          <h3>Contact Information</h3>
          <div class="contact-methods">
            <div class="contact-method">
              <span>📧</span>
              <div>
                <strong>Email</strong><br>
                <a href="mailto:jackafaris@gmail.com">jackafaris@gmail.com</a>
              </div>
            </div>
            
            <div class="contact-method">
              <span>💼</span>
              <div>
                <strong>LinkedIn</strong><br>
                <a href="https://www.linkedin.com/in/jack-faris" target="_blank" rel="noopener">linkedin.com/in/jack-faris</a>
              </div>
            </div>
            
            <div class="contact-method">
              <span>📍</span>
              <div>
                <strong>Location</strong><br>
                St. Louis, Missouri
              </div>
            </div>
          </div>
        </div>
        
        <div>
          <h3>What I'm Interested In</h3>
          <ul style="margin-top: var(--space-sm);">
            <li>Robotics and medical device opportunities</li>
            <li>Sales leadership and team development roles</li>
            <li>AI and automation consulting for small businesses</li>
            <li>Partnerships that create value for society</li>
            <li>Building something meaningful from the ground up</li>
          </ul>
          
          <div style="margin-top: var(--space-md);">
            <h3>Response Time</h3>
            <p>I typically respond to emails within 24-48 hours.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <section style="background: var(--color-accent-light);">
    <div class="container">
      <div style="text-align: center; max-width: 600px; margin: 0 auto;">
        <h2>Let's Build Something Together</h2>
        <p style="margin: var(--space-sm) 0;">My mission is to solve problems and create value. If you have a challenge that aligns with that mission, let's talk.</p>
        <a href="mailto:jackafaris@gmail.com" class="btn" style="margin-top: var(--space-sm);">Send an Email</a>
      </div>
    </div>
  </section>
</Layout>
